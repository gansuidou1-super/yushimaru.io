/* ============================================================
   足場の移動
   ============================================================ */
function updatePlatforms(dt){
  for(const pl of runtime.platforms){
    if(!pl.moving) continue;
    pl.phase += 0.02*dt;
    pl.y = pl.baseY + Math.sin(pl.phase)*30;
  }
}

/* ============================================================
   敵の更新
   ============================================================ */
function updateEnemies(dt){
  for(const en of runtime.enemies){
    if(!en.alive) continue;
    if(en.type === 'walker'){
      en.x += en.dir*en.speed*dt;
      if(en.x < en.minX){ en.x = en.minX; en.dir = 1; }
      if(en.x > en.maxX){ en.x = en.maxX; en.dir = -1; }
    } else if(en.type === 'flyer'){
      en.flyPhase += 0.04*dt;
      en.x += en.dir*en.speed*dt;
      if(en.x < en.minX){ en.x = en.minX; en.dir = 1; }
      if(en.x > en.maxX){ en.x = en.maxX; en.dir = -1; }
      en.y = en.baseY + Math.sin(en.flyPhase)*22;
    }
  }
  // ボススポーン
  if(stageDef.boss && !boss && !bossDefeatedThisStage){
    if(player.x + W*0.55 > stageDef.boss.x - 260){
      boss = { ...stageDef.boss, invuln:0, squish:0, dir:-1, defeated:false,
        deathTimer:0, attackTimer:90, projectiles:[] };
      bossActive = true;
      document.getElementById('bossName').textContent = boss.name;
      updateBossBar();
      document.getElementById('bossBarWrap').classList.add('show');
    }
  }
  if(boss && !boss.defeated){
    boss.x += boss.dir * 1.3 * dt;
    if(boss.x < boss.minX){ boss.x = boss.minX; boss.dir = 1; }
    if(boss.x > boss.maxX){ boss.x = boss.maxX; boss.dir = -1; }
    if(boss.type === 'bat'){
      boss.y = (stageDef.boss.y) + Math.sin(performance.now()/450)*26;
    }
    if(boss.invuln>0) boss.invuln -= dt;
    if(boss.squish>0) boss.squish = Math.max(0, boss.squish-0.04*dt);
    boss.attackTimer -= dt;
    if(boss.attackTimer<=0){
      boss.attackTimer = 110+Math.random()*40;
      if(boss.type !== 'crab'){
        const dx = (player.x - boss.x);
        const len = Math.hypot(dx, (player.y-boss.y)) || 1;
        boss.projectiles.push({
          x: boss.x+boss.w/2, y: boss.y+boss.h*0.4,
          vx: dx/len*4.2, vy: (player.y-boss.y)/len*4.2, r:9, alive:true, life:240,
        });
      }
    }
    for(const pr of boss.projectiles){
      if(!pr.alive) continue;
      pr.x += pr.vx*dt; pr.y += pr.vy*dt; pr.life -= dt;
      if(pr.life<=0) pr.alive=false;
      if(rectsOverlap(player.x,player.y,HIT_W,HIT_H, pr.x-pr.r,pr.y-pr.r,pr.r*2,pr.r*2)){
        pr.alive = false;
        damagePlayer(player.x<pr.x?-1:1);
      }
    }
    boss.projectiles = boss.projectiles.filter(p=>p.alive);
  } else if(boss && boss.defeated){
    boss.deathTimer -= dt;
  }
}

/* ============================================================
   描画：背景
   ============================================================ */
function drawBackground(){
  const g = ctx.createLinearGradient(0,0,0,GROUND_Y);
  g.addColorStop(0, stageDef.skyTop);
  g.addColorStop(1, stageDef.skyBottom);
  ctx.fillStyle = g;
  ctx.fillRect(0,0,W,H);

  // 雲
  ctx.fillStyle = 'rgba(255,255,255,0.55)';
  for(let i=0;i<6;i++){
    const cx = ((i*420 - camX*0.25) % (W+400)) - 200;
    const cy = 50 + (i%3)*30;
    drawCloud(cx, cy, 1+(i%2)*0.4);
  }

  // 遠景の山
  ctx.fillStyle = stageDef.hillColor2;
  drawHillRow(0.45, 120, GROUND_Y-40);
  ctx.fillStyle = stageDef.hillColor;
  drawHillRow(0.65, 90, GROUND_Y-10);
}
function drawCloud(x,y,scale){
  ctx.beginPath();
  ctx.ellipse(x,y,30*scale,16*scale,0,0,Math.PI*2);
  ctx.ellipse(x+26*scale,y-8*scale,22*scale,14*scale,0,0,Math.PI*2);
  ctx.ellipse(x-26*scale,y-4*scale,20*scale,13*scale,0,0,Math.PI*2);
  ctx.fill();
}
function drawHillRow(parallax, amp, baseY){
  const offset = -camX*parallax;
  ctx.beginPath();
  ctx.moveTo(0, baseY+60);
  for(let x=-200; x<=W+400; x+=80){
    const wx = x + (offset % 320);
    const yy = baseY - amp - Math.sin((x+camX*parallax)/220)*18;
    ctx.lineTo(wx, yy);
  }
  ctx.lineTo(W+400, baseY+60);
  ctx.closePath();
  ctx.fill();
}

function drawGround(){
  const x0 = -camX;
  ctx.fillStyle = stageDef.groundDark;
  ctx.fillRect(x0, GROUND_Y, stageDef.levelW, H-GROUND_Y+40);
  ctx.fillStyle = stageDef.groundTop;
  ctx.fillRect(x0, GROUND_Y, stageDef.levelW, 14);
  // ピット（落とし穴）
  for(const pr of stageDef.pits){
    const px = pr[0]-camX, pw = pr[1]-pr[0];
    ctx.clearRect(px, GROUND_Y-4, pw, H-GROUND_Y+44);
    ctx.fillStyle = 'rgba(0,0,0,0.35)';
    ctx.fillRect(px, GROUND_Y-4, pw, 8);
  }
}

function drawPlatforms(){
  for(const pl of runtime.platforms){
    const x = pl.x - camX;
    if(x+pl.w<0||x>W) continue;
    ctx.fillStyle = '#8a5a3a';
    ctx.fillRect(x, pl.y+6, pl.w, pl.h-6);
    ctx.fillStyle = stageDef.groundTop;
    ctx.fillRect(x, pl.y, pl.w, 8);
  }
}

function boneComposite(extra){
  // 中央バー
  roundRectPath(-13-extra, -4.2-extra, 26+extra*2, 8.4+extra*2, 4+extra);
  ctx.fill();
  // 両端のコブ（2つずつ）
  const knobs = [[-12,-4.6],[-12,4.6],[12,-4.6],[12,4.6]];
  knobs.forEach(([cx,cy])=>{
    ctx.beginPath();
    ctx.arc(cx, cy, 5.6+extra, 0, Math.PI*2);
    ctx.fill();
  });
}

function drawBoneShape(x,y,scale,rot,glowAlpha){
  ctx.save();
  ctx.translate(x,y);

  // ふわっと光るグロー
  const glow = ctx.createRadialGradient(0,0,0,0,0,26*scale);
  glow.addColorStop(0, 'rgba(255,236,170,'+(0.45*glowAlpha)+')');
  glow.addColorStop(1, 'rgba(255,236,170,0)');
  ctx.fillStyle = glow;
  ctx.beginPath(); ctx.arc(0,0,26*scale,0,Math.PI*2); ctx.fill();

  if(rot) ctx.rotate(rot);
  ctx.scale(scale,scale);

  // 落ち影
  ctx.save();
  ctx.translate(1.2,2.4);
  ctx.fillStyle = 'rgba(40,30,20,0.22)';
  boneComposite(0.4);
  ctx.restore();

  // 輪郭（少し大きめに描いて縁取りにする）
  ctx.fillStyle = '#6b5338';
  boneComposite(1.7);

  // 本体グラデーション
  const grad = ctx.createLinearGradient(0,-7,0,7);
  grad.addColorStop(0, '#fffdf6');
  grad.addColorStop(0.5, '#fff3da');
  grad.addColorStop(1, '#f0d9ad');
  ctx.fillStyle = grad;
  boneComposite(0);

  // ハイライト（つや）
  ctx.fillStyle = 'rgba(255,255,255,0.75)';
  ctx.beginPath();
  ctx.ellipse(-3,-2.6,8.5,2.1,-0.2,0,Math.PI*2);
  ctx.fill();
  ctx.beginPath();
  ctx.ellipse(11,-4.4,2.6,1.6,-0.3,0,Math.PI*2);
  ctx.fill();
  ctx.beginPath();
  ctx.ellipse(-11,-4.4,2.6,1.6,-0.3,0,Math.PI*2);
  ctx.fill();

  // 薄いシャドウライン（下側の丸み）
  ctx.strokeStyle = 'rgba(170,140,95,0.55)';
  ctx.lineWidth = 1.2;
  ctx.beginPath();
  ctx.moveTo(-9,4.4); ctx.lineTo(9,4.4);
  ctx.stroke();

  ctx.restore();
}

function drawSparkle(cx,cy,size,alpha,rot){
  ctx.save();
  ctx.translate(cx,cy);
  ctx.rotate(rot);
  ctx.globalAlpha = alpha;
  ctx.fillStyle = '#fff6cf';
  ctx.beginPath();
  ctx.moveTo(0,-size); ctx.lineTo(size*0.22,-size*0.22);
  ctx.lineTo(size,0); ctx.lineTo(size*0.22,size*0.22);
  ctx.lineTo(0,size); ctx.lineTo(-size*0.22,size*0.22);
  ctx.lineTo(-size,0); ctx.lineTo(-size*0.22,-size*0.22);
  ctx.closePath();
  ctx.fill();
  ctx.restore();
}

function roundRectPath(x,y,w,h,r){
  ctx.beginPath();
  ctx.moveTo(x+r,y);
  ctx.arcTo(x+w,y,x+w,y+h,r);
  ctx.arcTo(x+w,y+h,x,y+h,r);
  ctx.arcTo(x,y+h,x,y,r);
  ctx.arcTo(x,y,x+w,y,r);
  ctx.closePath();
}

function drawBones(){
  for(const b of runtime.bones){
    if(b.collected) continue;
    const x = b.x-camX;
    if(x<-40||x>W+40) continue;
    const t = performance.now();
    const yy = b.baseY + Math.sin(t/260 + b.bob)*6;
    const glowAlpha = 0.6 + Math.sin(t/300 + b.bob)*0.4;
    drawBoneShape(x, yy, 1.55, Math.sin(t/400+b.bob)*0.22, glowAlpha);
    const sparkAlpha = Math.max(0, Math.sin(t/260 + b.bob*1.7));
    if(sparkAlpha > 0.55){
      drawSparkle(x+15, yy-13, 4.5, (sparkAlpha-0.55)*2.2, t/500);
    }
  }
}

function drawGoal(){
  if(stageDef.boss && !bossDefeatedThisStage) return;
  const x = stageDef.goalX - camX;
  if(x<-60||x>W+60) return;
  ctx.fillStyle = '#8a5a2e';
  ctx.fillRect(x, 220, 7, GROUND_Y-220);
  const wave = Math.sin(performance.now()/300)*6;
  ctx.fillStyle = '#ff9447';
  ctx.beginPath();
  ctx.moveTo(x+7,222);
  ctx.lineTo(x+62+wave,236);
  ctx.lineTo(x+7,252);
  ctx.closePath();
  ctx.fill();
  ctx.fillStyle = '#4fb3ff';
  ctx.beginPath();
  ctx.arc(x+3,218,9,0,Math.PI*2);
  ctx.fill();
}

function drawParticles(){
  for(const p of particles){
    ctx.globalAlpha = Math.max(0, p.life/28);
    ctx.fillStyle = p.color;
    ctx.beginPath();
    ctx.arc(p.x-camX, p.y, 3.4, 0, Math.PI*2);
