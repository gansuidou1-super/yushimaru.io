/* ============================================================
   パーティクル
   ============================================================ */
function spawnParticles(x,y,color,count,spreadV){
  for(let i=0;i<count;i++){
    particles.push({
      x, y, vx:(Math.random()-0.5)*spreadV, vy:(Math.random()-1.2)*spreadV,
      life:26+Math.random()*10, color,
    });
  }
}
function updateParticles(dt){
  for(let i=particles.length-1;i>=0;i--){
    const p = particles[i];
    p.x += p.vx*dt; p.y += p.vy*dt; p.vy += 0.35*dt;
    p.life -= dt;
    if(p.life<=0) particles.splice(i,1);
  }
}

/* ============================================================
   プレイヤー更新
   ============================================================ */
function damagePlayer(knockDir){
  if(invTimer>0) return;
  lives--;
  invTimer = 90;
  player.vy = -7;
  player.vx = 6*knockDir;
  player.hurtTimer = 360;
  sfxHurt();
  updateHud();
  if(lives<=0){
    triggerGameOver();
  }
}

function killEnemy(en, bounce){
  en.alive = false;
  score += 50;
  spawnParticles(en.x+en.w/2, en.y+en.h/2, '#fff3c4', 10, 5);
  sfxStomp();
  if(bounce) player.vy = JUMP_V*0.55;
  updateHud();
}

function rectsOverlap(ax,ay,aw,ah,bx,by,bw,bh){
  return ax < bx+bw && ax+aw > bx && ay < by+bh && ay+ah > by;
}

function isPit(x){
  for(const pr of stageDef.pits){ if(x > pr[0]-10 && x < pr[1]+10) return true; }
  return false;
}

function updatePlayer(dt){
  const dashHeld = keys.dash;
  let targetVx = 0;
  if(keys.left){ targetVx -= MOVE_SPEED; player.facing = -1; }
  if(keys.right){ targetVx += MOVE_SPEED; player.facing = 1; }
  if(targetVx !== 0 && dashHeld){
    targetVx = Math.sign(targetVx) * DASH_SPEED;
    player.dashing = true;
  } else {
    player.dashing = false;
  }
  player.vx += (targetVx - player.vx) * Math.min(1, 0.45*dt);
  if(Math.abs(player.vx) < 0.05) player.vx = 0;

  // ジャンプ（押した瞬間のみ判定 = 二段ジャンプ管理）
  if(keys.jump && !prevJump){
    if(player.onGround){
      player.vy = JUMP_V; player.jumpsUsed = 1; player.onGround = false; sfxJump();
      spawnParticles(player.x+HIT_W/2, player.y+HIT_H, '#ffffff', 4, 2);
    } else if(player.jumpsUsed < 2){
      player.vy = JUMP2_V; player.jumpsUsed = 2; sfxDoubleJump();
      spawnParticles(player.x+HIT_W/2, player.y+HIT_H/2, '#cfe8ff', 8, 3.5);
    }
  }
  prevJump = keys.jump;

  player.vy += GRAVITY*dt;
  if(player.vy > MAX_FALL) player.vy = MAX_FALL;

  player.x += player.vx*dt;
  player.y += player.vy*dt;
  if(player.x < 0) player.x = 0;
  if(player.x > stageDef.levelW - HIT_W) player.x = stageDef.levelW - HIT_W;

  // 地面・足場あたり判定
  player.onGround = false;
  const feetY = player.y + HIT_H;
  if(player.vy >= 0){
    // 通常の地面
    if(!isPit(player.x+HIT_W/2) && feetY >= GROUND_Y && feetY - player.vy*dt <= GROUND_Y+2){
      player.y = GROUND_Y - HIT_H; player.vy = 0; player.onGround = true; player.jumpsUsed = 0;
    }
    // 足場
    for(const pl of runtime.platforms){
      const py = pl.y;
      if(feetY >= py && feetY - player.vy*dt <= py+10 &&
         player.x+HIT_W > pl.x && player.x < pl.x+pl.w){
        player.y = py - HIT_H; player.vy = 0; player.onGround = true; player.jumpsUsed = 0;
      }
    }
  }

  // 落下死（ピット）
  if(player.y > GROUND_Y + 220){
    damagePlayer(-player.facing);
    player.x = Math.max(40, camX+40);
    player.y = GROUND_Y - HIT_H - 40;
    player.vy = 0;
  }

  if(invTimer>0) invTimer -= dt;
  if(player.hurtTimer>0) player.hurtTimer -= dt*16.6667;

  // ほね収集
  for(const b of runtime.bones){
    if(b.collected) continue;
    const dx = (player.x+HIT_W/2) - b.x, dy = (player.y+HIT_H/2) - b.y;
    if(dx*dx+dy*dy < (b.r+18)*(b.r+18)){
      b.collected = true; score += 10; sfxBone();
      spawnParticles(b.x,b.y,'#fff6e6',6,3);
      updateHud();
    }
  }

  // 敵あたり判定
  for(const en of runtime.enemies){
    if(!en.alive) continue;
    if(rectsOverlap(player.x,player.y,HIT_W,HIT_H, en.x,en.y,en.w,en.h)){
      const stomp = player.vy > 1 && (player.y + HIT_H - player.vy*dt) <= en.y + en.h*0.5;
      if(stomp){
        killEnemy(en, true);
      } else {
        damagePlayer(player.x < en.x ? -1 : 1);
      }
    }
  }

  // ボス
  if(boss && !boss.defeated){
    if(rectsOverlap(player.x,player.y,HIT_W,HIT_H, boss.x,boss.y,boss.w,boss.h)){
      const stomp = player.vy > 1 && (player.y + HIT_H - player.vy*dt) <= boss.y + boss.h*0.42 && boss.invuln<=0;
      if(stomp){
        boss.hp--; boss.invuln = 50; boss.squish = 0.4;
        player.vy = JUMP_V*0.6;
        spawnParticles(boss.x+boss.w/2, boss.y+boss.h*0.4, '#ffd1d1', 10, 5);
        sfxBossHit();
        updateBossBar();
        if(boss.hp<=0){
          boss.defeated = true; boss.deathTimer = 60; bossDefeatedThisStage = true;
          score += 500; sfxBossDefeat(); updateHud();
          document.getElementById('bossBarWrap').classList.remove('show');
        }
      } else if(boss.invuln<=0){
        damagePlayer(player.x < boss.x ? -1 : 1);
      }
    }
  }

  // ゴール判定
  if(!goalReached && (!stageDef.boss || bossDefeatedThisStage) && player.x+HIT_W/2 > stageDef.goalX){
    goalReached = true;
    player.celebrate = true;
    sfxGoal();
    goalTimer = 70;
  }

  // アニメーション状態決定
  let state;
  if(!player.onGround) state = player.vy < 0 ? 'jump' : 'fall';
  else if(Math.abs(player.vx) > 3.2) state = 'run';
  else if(Math.abs(player.vx) > 0.3) state = 'walk';
  else state = 'idle';
  if(state !== player.animState){ player.animState = state; player.animIndex = 0; player.animAcc = 0; }
  if(state==='idle' || state==='walk' || state==='run'){
    const a = ANIM[state];
    player.animAcc += dt*16.6667;
    while(player.animAcc >= a.interval){
      player.animAcc -= a.interval;
      player.animIndex = (player.animIndex+1) % a.frames.length;
    }
  }
}

/* ============================================================
   描画：敵
   ============================================================ */
function drawEnemy(en){
  if(!en.alive) return;
  const x = en.x - camX;
  if(x+en.w<-20||x>W+20) return;
  ctx.save();
  ctx.translate(x+en.w/2, en.y+en.h);
  ctx.scale(en.dir<0?1:-1, 1);
  const bob = en.type==='walker' ? Math.sin(performance.now()/120 + en.x)*2 : 0;
  ctx.translate(0, bob);
  if(en.type==='walker'){
    ctx.fillStyle = '#8a5fd6';
    ctx.beginPath();
    ctx.ellipse(0,-en.h*0.5, en.w*0.42, en.h*0.42, 0,0,Math.PI*2);
    ctx.fill();
    ctx.fillStyle = '#6c3fb5';
    ctx.beginPath(); ctx.moveTo(-en.w*0.18,-en.h*0.82); ctx.lineTo(-en.w*0.05,-en.h*1.05); ctx.lineTo(en.w*0.05,-en.h*0.8); ctx.closePath(); ctx.fill();
    ctx.beginPath(); ctx.moveTo(en.w*0.05,-en.h*0.82); ctx.lineTo(en.w*0.2,-en.h*1.05); ctx.lineTo(en.w*0.28,-en.h*0.78); ctx.closePath(); ctx.fill();
    ctx.fillStyle = '#fff';
    ctx.beginPath(); ctx.arc(-10,-en.h*0.55,6,0,Math.PI*2); ctx.arc(8,-en.h*0.55,6,0,Math.PI*2); ctx.fill();
    ctx.fillStyle = '#241733';
    ctx.beginPath(); ctx.arc(-8,-en.h*0.55,2.6,0,Math.PI*2); ctx.arc(10,-en.h*0.55,2.6,0,Math.PI*2); ctx.fill();
  } else {
    ctx.fillStyle = '#ff8a5c';
    const flap = Math.sin(performance.now()/110)*10;
    ctx.beginPath(); ctx.ellipse(0,-en.h*0.5,en.w*0.3,en.h*0.32,0,0,Math.PI*2); ctx.fill();
    ctx.fillStyle = '#d65f37';
    ctx.beginPath();
    ctx.moveTo(-en.w*0.2,-en.h*0.5);
    ctx.quadraticCurveTo(-en.w*0.6,-en.h*0.7-flap,-en.w*0.5,-en.h*0.2);
    ctx.quadraticCurveTo(-en.w*0.35,-en.h*0.35,-en.w*0.2,-en.h*0.5);
    ctx.fill();
    ctx.beginPath();
    ctx.moveTo(en.w*0.2,-en.h*0.5);
    ctx.quadraticCurveTo(en.w*0.6,-en.h*0.7-flap,en.w*0.5,-en.h*0.2);
    ctx.quadraticCurveTo(en.w*0.35,-en.h*0.35,en.w*0.2,-en.h*0.5);
    ctx.fill();
    ctx.fillStyle = '#fff';
    ctx.beginPath(); ctx.arc(-8,-en.h*0.55,5,0,Math.PI*2); ctx.arc(8,-en.h*0.55,5,0,Math.PI*2); ctx.fill();
    ctx.fillStyle = '#241733';
    ctx.beginPath(); ctx.arc(-6,-en.h*0.55,2.2,0,Math.PI*2); ctx.arc(10,-en.h*0.55,2.2,0,Math.PI*2); ctx.fill();
  }
  ctx.restore();
}

/* ============================================================
   描画：ボス
   ============================================================ */
function drawBoss(){
  if(!boss) return;
  const x = boss.x-camX;
  if(x<-160||x>W+160) return;
  ctx.save();
  if(boss.invuln>0 && Math.floor(boss.invuln/4)%2===0) ctx.globalAlpha = 0.5;
  if(boss.defeated) ctx.globalAlpha = Math.max(0, boss.deathTimer/60);
  ctx.translate(x+boss.w/2, boss.y+boss.h);
  const sq = 1+boss.squish;
  ctx.scale(sq*(boss.dir<0?1:-1), 1/sq);

  if(boss.type==='crab'){
    ctx.fillStyle = '#e8534a';
    ctx.beginPath(); ctx.ellipse(0,-boss.h*0.42,boss.w*0.5,boss.h*0.4,0,0,Math.PI*2); ctx.fill();
    ctx.fillStyle='#c93a30';
    ctx.beginPath(); ctx.ellipse(-boss.w*0.48,-boss.h*0.55,18,12,0.4,0,Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.ellipse(boss.w*0.48,-boss.h*0.55,18,12,-0.4,0,Math.PI*2); ctx.fill();
    ctx.strokeStyle='#c93a30'; ctx.lineWidth=6;
    for(let i=-2;i<=2;i++){ ctx.beginPath(); ctx.moveTo(i*16,-boss.h*0.18); ctx.lineTo(i*20,0); ctx.stroke(); }
    ctx.fillStyle='#fff';
    ctx.beginPath(); ctx.arc(-14,-boss.h*0.7,10,0,Math.PI*2); ctx.arc(14,-boss.h*0.7,10,0,Math.PI*2); ctx.fill();
    ctx.fillStyle='#2a1f3d';
    ctx.beginPath(); ctx.arc(-12,-boss.h*0.7,4.4,0,Math.PI*2); ctx.arc(16,-boss.h*0.7,4.4,0,Math.PI*2); ctx.fill();
  } else if(boss.type==='bat'){
    ctx.fillStyle = '#5c3aa0';
    ctx.beginPath(); ctx.ellipse(0,-boss.h*0.5,boss.w*0.36,boss.h*0.42,0,0,Math.PI*2); ctx.fill();
    const wingFlap = Math.sin(performance.now()/130)*14;
    ctx.fillStyle='#3c2570';
    ctx.beginPath();
    ctx.moveTo(-boss.w*0.32,-boss.h*0.5);
    ctx.quadraticCurveTo(-boss.w*0.75,-boss.h*0.7-wingFlap,-boss.w*0.62,-boss.h*0.2);
    ctx.quadraticCurveTo(-boss.w*0.5,-boss.h*0.35,-boss.w*0.32,-boss.h*0.5);
    ctx.fill();
    ctx.beginPath();
    ctx.moveTo(boss.w*0.32,-boss.h*0.5);
    ctx.quadraticCurveTo(boss.w*0.75,-boss.h*0.7-wingFlap,boss.w*0.62,-boss.h*0.2);
    ctx.quadraticCurveTo(boss.w*0.5,-boss.h*0.35,boss.w*0.32,-boss.h*0.5);
    ctx.fill();
    ctx.fillStyle='#ffd34d';
    ctx.beginPath(); ctx.arc(-12,-boss.h*0.55,8,0,Math.PI*2); ctx.arc(12,-boss.h*0.55,8,0,Math.PI*2); ctx.fill();
    ctx.fillStyle='#2a1f3d';
    ctx.beginPath(); ctx.arc(-10,-boss.h*0.55,3.6,0,Math.PI*2); ctx.arc(14,-boss.h*0.55,3.6,0,Math.PI*2); ctx.fill();
  } else if(boss.type==='golem'){
    ctx.fillStyle = '#9aa6b8';
    roundRectPath(-boss.w*0.45,-boss.h*0.95,boss.w*0.9,boss.h*0.95,16); ctx.fill();
    ctx.fillStyle = '#7d8aa0';
    roundRectPath(-boss.w*0.45,-boss.h*0.4,boss.w*0.9,boss.h*0.4,10); ctx.fill();
    ctx.fillStyle='#cfe8ff';
    ctx.beginPath(); ctx.arc(-16,-boss.h*0.72,9,0,Math.PI*2); ctx.arc(16,-boss.h*0.72,9,0,Math.PI*2); ctx.fill();
    ctx.fillStyle='#2a1f3d';
    ctx.beginPath(); ctx.arc(-14,-boss.h*0.72,4,0,Math.PI*2); ctx.arc(18,-boss.h*0.72,4,0,Math.PI*2); ctx.fill();
  }
  ctx.restore();

  if(boss.projectiles){
    boss.projectiles.forEach(p=>{
      if(!p.alive) return;
      const px = p.x-camX;
      ctx.fillStyle = '#cfa8ff';
      ctx.beginPath(); ctx.arc(px,p.y,p.r,0,Math.PI*2); ctx.fill();
      ctx.fillStyle = 'rgba(255,255,255,.5)';
      ctx.beginPath(); ctx.arc(px-2,p.y-2,p.r*0.4,0,Math.PI*2); ctx.fill();
    });
  }
}

/* ============================================================
   描画：プレイヤー（実スプライト使用）
   ============================================================ */
function currentFrameKey(){
  if(player.hurtTimer > 0) return 'bark';
  if(player.celebrate) return 'sit';
  const st = player.animState;
  if(st==='jump') return 'jump';
  if(st==='fall') return 'fall';
  return ANIM[st].frames[player.animIndex];
}

const FRAME_SCALE = { jump:1.22, fall:1.08, sit:1.05 };

function drawPlayer(){
  const sx = player.x - camX;
  const cx = sx + HIT_W/2;
  const feetY = player.y + HIT_H;

  const key = currentFrameKey();
  const img = frameImgs[key];
  let drawW = HIT_W*1.6, drawH = DRAW_H;
  if(img && img.naturalWidth){
    drawH = DRAW_H * (FRAME_SCALE[key]||1);
    drawW = drawH * (img.naturalWidth/img.naturalHeight);
  }

  ctx.save();
  if(invTimer>0 && Math.floor(invTimer/4)%2===0) ctx.globalAlpha = 0.4;

  // 影
  ctx.fillStyle = 'rgba(20,20,30,.28)';
  ctx.beginPath();
  ctx.ellipse(cx, feetY+4, HIT_W*0.62, 7, 0, 0, Math.PI*2);
  ctx.fill();

  ctx.translate(cx, feetY);
  ctx.scale(player.facing, 1);
  if(img && img.naturalWidth){
    ctx.drawImage(img, -drawW/2, -drawH, drawW, drawH);
  } else {
    ctx.fillStyle = '#333';
    ctx.fillRect(-drawW/2,-drawH,drawW,drawH);
  }

  if(player.dashing){
    ctx.globalAlpha *= 0.55;
    ctx.strokeStyle = '#fff';
    ctx.lineWidth = 3;
    for(let i=0;i<3;i++){
      ctx.beginPath();
      const ly = -drawH*0.3 - i*drawH*0.2;
      ctx.moveTo(-drawW*0.5-6-i*4, ly);
      ctx.lineTo(-drawW*0.5-18-i*6, ly);
      ctx.stroke();
    }
  }
  ctx.restore();
}

function draw(){
  drawBackground();
  drawGround();
  drawPlatforms();
  drawBones();
  runtime.enemies.forEach(drawEnemy);
  drawBoss();
  drawGoal();
  drawPlayer();
  drawParticles();
}

/* ============================================================
   メインループ
   ============================================================ */
let lastTime = performance.now();
function loop(now){
  let dt = (now-lastTime)/16.6667;
  dt = Math.max(0, Math.min(2, dt));
  lastTime = now;

  if(gameState==='playing'){
    updatePlatforms(dt);
    updatePlayer(dt);
    if(gameState==='playing'){
      updateEnemies(dt);
      updateParticles(dt);
      camX = Math.max(0, Math.min(stageDef.levelW-W, player.x+HIT_W/2-W/2));
      if(goalReached){
        goalTimer -= dt;
        if(goalTimer<=0){
          onStageCleared();
        }
      }
    }
  }
  draw();
  requestAnimationFrame(loop);
}

/* ============================================================
   画面遷移
   ============================================================ */
function hideAllOverlays(){
  document.getElementById('startScreen').classList.add('hidden');
  document.getElementById('clearScreen').classList.add('hidden');
  document.getElementById('overScreen').classList.add('hidden');
  document.getElementById('stageClearScreen').classList.add('hidden');
}

function startGame(fromIdx){
  ensureAudio();
  if(audioCtx.state==='suspended') audioCtx.resume();
  hideAllOverlays();
  lives = 3; score = 0;
  totalElapsed = 0;
  gameState = 'playing';
  loadStage(fromIdx||0, true);
  updateHud();
}

function onStageCleared(){
  gameState = 'clear-pending';
  totalElapsed += performance.now() - stageStartTime;
  sfxStageClear();
  if(currentStageIndex >= unlockedStageIndex){
    unlockedStageIndex = Math.min(STAGES.length-1, currentStageIndex+1);
  }
  if(currentStageIndex >= STAGES.length-1){
    document.getElementById('clearScore').textContent = score;
    const totalSec = totalElapsed/1000;
    const mm = Math.floor(totalSec/60), ss = (totalSec%60).toFixed(2).padStart(5,'0');
    document.getElementById('clearTime').textContent = mm+':'+ss;
    document.getElementById('clearScreen').classList.remove('hidden');
  } else {
    document.getElementById('stageClearName').textContent = STAGES[currentStageIndex].name;
    document.getElementById('stageClearScore').textContent = score;
    document.getElementById('stageClearScreen').classList.remove('hidden');
  }
}

function triggerGameOver(){
  gameState = 'over';
  sfxOver();
  document.getElementById('overScore').textContent = score;
  document.getElementById('overMascot').src = SPRITE_B64.sleep;
  setTimeout(()=>document.getElementById('overScreen').classList.remove('hidden'), 400);
}

function buildStageSelect(){
  const wrap = document.getElementById('stageSelectList');
  wrap.innerHTML = '';
  STAGES.forEach((st,i)=>{
    const b = document.createElement('button');
    b.className = 'stageBtn';
    b.innerHTML = '<span class="stageBtnTitle">STAGE '+(i+1)+'</span>'+st.name;
    b.disabled = i>unlockedStageIndex;
    b.addEventListener('click', ()=>{ if(!b.disabled) startGame(i); });
    wrap.appendChild(b);
  });
}

document.getElementById('startBtn').addEventListener('click', ()=>startGame(0));
document.getElementById('retryBtnClear').addEventListener('click', ()=>{ unlockedStageIndex=0; buildStageSelect(); hideAllOverlays(); document.getElementById('clearScreen').classList.add('hidden'); document.getElementById('startScreen').classList.remove('hidden'); gameState='start'; });
document.getElementById('retryBtnOver').addEventListener('click', ()=>{ hideAllOverlays(); document.getElementById('overScreen').classList.add('hidden'); document.getElementById('startScreen').classList.remove('hidden'); gameState='start'; });
document.getElementById('nextStageBtn').addEventListener('click', ()=>{
  hideAllOverlays();
  const next = currentStageIndex+1;
  loadStage(next, true);
  gameState='playing';
});

gameState = 'start';
score = 0; lives = 3; particles = []; camX = 0;
stageDef = STAGES[0];
runtime = deepCopyStage(stageDef);
resetPlayer(40);
buildStageSelect();
updateHud();
draw();
requestAnimationFrame(loop);

})();
</script>
