<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>ジャックのほねほね大冒険</title>
<style>
  :root{
    --sky-dark:#27314f;
    --accent:#4fb3ff;
    --accent-light:#9fe0ff;
    --bone:#fff6e6;
    --bone-line:#5a4632;
    --cream:#fff6ea;
    --ink:#1f2638;
    --warn:#ff7043;
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  html,body{
    margin:0;padding:0;
    width:100%;height:100%;
    background:#10131f;
    font-family:"Hiragino Maru Gothic ProN","Yu Gothic","Segoe UI",sans-serif;
    overflow:hidden;
    touch-action:none;
    -webkit-user-select:none; user-select:none;
  }
  #stage{
    position:fixed; inset:0;
    display:flex; align-items:center; justify-content:center;
    background:#10131f;
  }
  #wrap{
    position:relative;
    overflow:hidden;
    border-radius:14px;
    box-shadow:0 0 0 4px #1c2236, 0 0 0 7px var(--accent), 0 18px 50px rgba(0,0,0,.55);
    touch-action:none;
  }
  canvas{
    display:block;
    width:100%;height:100%;
    image-rendering:pixelated;
    image-rendering:-moz-crisp-edges;
    background:#8ed8ff;
    touch-action:none;
  }
  .overlay{
    position:absolute;inset:0;
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    text-align:center;
    background:rgba(20,24,40,.92);
    color:var(--cream);
    gap:12px;
    padding:14px;
    z-index:20;
  }
  .overlay.hidden{display:none;}
  .overlay h1{
    margin:0;
    font-size:clamp(18px,4.4vw,34px);
    color:var(--accent-light);
    text-shadow:3px 3px 0 var(--ink);
    letter-spacing:1px;
    line-height:1.3;
  }
  .overlay h2{
    margin:0;
    font-size:clamp(14px,3vw,22px);
    color:var(--accent-light);
    text-shadow:2px 2px 0 var(--ink);
  }
  .overlay p{
    margin:0;
    font-size:clamp(11px,2vw,15px);
    line-height:1.7;
    max-width:90%;
    color:#cfe3ff;
  }
  .overlay .score-line{
    font-size:clamp(15px,2.6vw,22px);
    color:#fff;
    font-weight:bold;
  }
  .mascot{
    width:64px;height:auto;image-rendering:pixelated;
    filter:drop-shadow(0 4px 6px rgba(0,0,0,.4));
  }
  .btn{
    appearance:none;border:none;cursor:pointer;
    font-family:inherit;font-weight:bold;
    font-size:clamp(13px,2.2vw,17px);
    color:#fff;
    background:linear-gradient(180deg,var(--accent) 0%, #1d7fc7 100%);
    padding:11px 28px;
    border-radius:999px;
    box-shadow:0 5px 0 #145a8e, 0 8px 14px rgba(0,0,0,.35);
    transition:transform .08s ease;
    touch-action:manipulation;
  }
  .btn:active{transform:translateY(4px);box-shadow:0 1px 0 #145a8e;}
  .btn.secondary{
    background:linear-gradient(180deg,#8a6bd8 0%, #5c3aa0 100%);
    box-shadow:0 5px 0 #3c2570, 0 8px 14px rgba(0,0,0,.35);
  }
  .btn.secondary:active{box-shadow:0 1px 0 #3c2570;}

  #hud{
    position:absolute;top:0;left:0;right:0;
    display:flex;justify-content:space-between;align-items:flex-start;
    padding:8px 10px;
    pointer-events:none;
    font-weight:bold;
    color:#fff;
    text-shadow:2px 2px 0 rgba(0,0,0,.35);
    z-index:5;
  }
  #hud .pill{
    background:rgba(20,24,40,.55);
    border:2px solid rgba(255,255,255,.25);
    border-radius:999px;
    padding:5px 11px;
    font-size:clamp(11px,1.9vw,15px);
    display:flex;align-items:center;gap:5px;
    white-space:nowrap;
  }
  #soundBtn{
    pointer-events:auto;cursor:pointer;
    background:rgba(20,24,40,.55);
    border:2px solid rgba(255,255,255,.25);
    border-radius:50%;
    width:34px;height:34px;
    display:flex;align-items:center;justify-content:center;
    font-size:16px;color:#fff;
    touch-action:manipulation;
  }

  #bossBarWrap{
    position:absolute;
    top:48px;left:50%;
    transform:translateX(-50%);
    width:min(72%,400px);
    pointer-events:none;
    text-align:center;
    opacity:0;
    transition:opacity .3s ease;
    z-index:5;
  }
  #bossBarWrap.show{opacity:1;}
  #bossBarWrap .bossName{
    color:#fff;font-weight:bold;font-size:12px;
    text-shadow:2px 2px 0 rgba(0,0,0,.5);
    margin-bottom:3px;
  }
  #bossBarOuter{
    height:12px;border-radius:8px;
    background:rgba(0,0,0,.45);
    border:2px solid rgba(255,255,255,.4);
    overflow:hidden;
  }
  #bossBarInner{
    height:100%;
    background:linear-gradient(180deg,#ff6b6b,#c93a48);
    width:100%;
    transition:width .15s ease;
  }

  #touchControls{
    position:absolute;bottom:0;left:0;right:0;
    display:flex;justify-content:space-between;align-items:flex-end;
    padding:0 10px 12px;
    pointer-events:none;
    z-index:6;
  }
  #touchControls .side{display:flex;gap:10px;pointer-events:auto;align-items:flex-end;}
  .tbtn{
    border-radius:16px;
    background:rgba(255,255,255,.16);
    border:2px solid rgba(255,255,255,.38);
    color:#fff;font-size:22px;font-weight:bold;
    display:flex;align-items:center;justify-content:center;
    user-select:none;-webkit-user-select:none;touch-action:none;
    width:56px;height:56px;
  }
  .tbtn.wide{width:74px;font-size:12px;}
  .tbtn.big{width:70px;height:70px;font-size:26px;}
  .tbtn.active{background:rgba(255,255,255,.42);}

  #hint{
    position:absolute;left:0;right:0;bottom:4px;
    text-align:center;color:rgba(255,255,255,.5);
    font-size:11px;pointer-events:none;
    z-index:5;
  }
  @media (max-width:680px){ #hint{display:none;} }

  #rotateHint{
    position:fixed; inset:0; z-index:50;
    background:rgba(10,12,20,.92);
    color:#fff;
    display:none;
    flex-direction:column; align-items:center; justify-content:center;
    gap:14px; text-align:center; padding:20px;
    font-size:15px;
  }
  #rotateHint .rotIcon{ font-size:46px; animation:rotSpin 1.6s ease-in-out infinite; }
  @keyframes rotSpin{
    0%,100%{ transform:rotate(0deg); }
    50%{ transform:rotate(90deg); }
  }
  @media (max-width:700px) and (orientation:portrait){
    #rotateHint.enabled{ display:flex; }
  }

  .stageSelectList{
    display:flex;gap:8px;flex-wrap:wrap;justify-content:center;
    max-width:92%;
  }
  .stageBtn{
    appearance:none;cursor:pointer;font-family:inherit;font-weight:bold;
    font-size:clamp(10px,1.8vw,13px);color:#fff;
    background:rgba(255,255,255,.12);
    border:2px solid rgba(255,255,255,.3);
    border-radius:12px;
    padding:7px 12px;
    text-align:left;
    min-width:104px;
    touch-action:manipulation;
  }
  .stageBtn:disabled{opacity:.35;cursor:not-allowed;}
  .stageBtn .stageBtnTitle{display:block;font-size:1.05em;margin-bottom:2px;color:var(--accent-light);}

  #stageBanner{
    position:absolute;
    top:36%;left:0;right:0;
    text-align:center;
    pointer-events:none;
    opacity:0;
    transform:translateY(10px);
    transition:opacity .45s ease, transform .45s ease;
    z-index:8;
  }
  #stageBanner.show{opacity:1;transform:translateY(0);}
  #stageBanner .stageBannerSmall{
    color:var(--accent-light);
    font-size:clamp(12px,2.3vw,17px);
    font-weight:bold;
    text-shadow:2px 2px 0 var(--ink);
    letter-spacing:2px;
  }
  #stageBanner .stageBannerMain{
    color:#fff;
    font-size:clamp(20px,4.8vw,38px);
    font-weight:bold;
    text-shadow:3px 3px 0 var(--ink), 0 0 18px rgba(0,0,0,.4);
    margin-top:2px;
  }
</style>
</head>
<body>
<div id="rotateHint" class="enabled">
  <div class="rotIcon">📱</div>
  <div>横向きにすると<br>もっと遊びやすくなります！</div>
  <button class="btn secondary" id="rotateDismiss" style="margin-top:6px;">このまま続ける</button>
</div>
<div id="stage">

<div id="wrap">
  <canvas id="game" width="800" height="450"></canvas>

  <div id="hud">
    <div style="display:flex;gap:6px;">
      <div class="pill" id="scorePill">🦴 <span id="scoreVal">0</span></div>
      <div class="pill" id="stagePill">🗺️ <span id="stageVal">1</span>/<span id="stageMaxVal">3</span></div>
    </div>
    <div style="display:flex;gap:6px;align-items:center;">
      <div class="pill" id="livesPill">♥ <span id="livesVal">3</span></div>
      <div id="soundBtn">🔊</div>
    </div>
  </div>

  <div id="bossBarWrap">
    <div class="bossName" id="bossName">BOSS</div>
    <div id="bossBarOuter"><div id="bossBarInner"></div></div>
  </div>

  <div id="stageBanner">
    <div class="stageBannerSmall" id="stageBannerSmall">STAGE 1</div>
    <div class="stageBannerMain" id="stageBannerMain">はじまりの草原</div>
  </div>

  <div id="touchControls">
    <div class="side">
      <div class="tbtn" id="btnLeft">◀</div>
      <div class="tbtn" id="btnRight">▶</div>
      <div class="tbtn wide" id="btnDash">ダッシュ</div>
    </div>
    <div class="side">
      <div class="tbtn big" id="btnJump">⤒</div>
    </div>
  </div>

  <div id="hint">← → で移動 ／ スペース（または ↑）でジャンプ（2段可）／ Shiftでダッシュ</div>

  <div class="overlay" id="startScreen">
    <h1>ジャックの<br>ほねほね大冒険</h1>
    <p>← → キー（またはボタン）で移動、スペース/↑/⤒ボタンでジャンプ！空中でもう一度押すと2段ジャンプ。<br>
    Shift（またはダッシュボタン）で走る！ほねを集めてスコアを稼ぎ、各ステージのゴールを目指そう。<br>
    敵は踏みつけてやっつけよう。ボスには連続踏みつけ攻撃だ！</p>
    <button class="btn" id="startBtn">▶ ゲームスタート</button>
    <div class="stageSelectList" id="stageSelectList"></div>
  </div>

  <div class="overlay hidden" id="stageClearScreen">
    <h1>🎉 STAGE CLEAR!! 🎉</h1>
    <h2 id="stageClearName">STAGE 1</h2>
    <div class="score-line">スコア：<span id="stageClearScore">0</span></div>
    <p id="stageClearMsg">見事ステージクリア！次のステージへ進もう。</p>
    <button class="btn" id="nextStageBtn">▶ 次のステージへ</button>
  </div>

  <div class="overlay hidden" id="clearScreen">
    <h1>🏆 ALL CLEAR!! 🏆</h1>
    <div class="score-line">トータルスコア：<span id="clearScore">0</span></div>
    <div class="score-line">クリアタイム：<span id="clearTime">0:00.00</span></div>
    <p>全ステージ制覇！ジャックのほねほね大冒険、クリア！おつかれさま！</p>
    <button class="btn" id="retryBtnClear">もう一度あそぶ</button>
  </div>

  <div class="overlay hidden" id="overScreen">
    <img class="mascot" id="overMascot" alt="sleeping husky">
    <h1>GAME OVER</h1>
    <div class="score-line">スコア：<span id="overScore">0</span></div>
    <p>残念...！もう一度チャレンジしよう。</p>
    <button class="btn" id="retryBtnOver">リトライ</button>
  </div>
</div>
</div>

<script>
(function(){
"use strict";

const SPRITE_B64 = {
  idle1: "data:image/png;base64,",
  idle2: "data:image/png;base64,",
  idle3: "data:image/png;base64,",
  walk1: "data:image/png;base64,",
  walk2: "data:image/png;base64,",
  walk3: "data:image/png;base64,",
  walk4: "data:image/png;base64,",
  run1: "data:image/png;base64,",
  run2: "data:image/png;base64,",
  run3: "data:image/png;base64,",
  run4: "data:image/png;base64,",
  jump: "data:image/png;base64,",
  fall: "data:image/png;base64,",
  sit: "data:image/png;base64,",
  bark: "data:image/png;base64,",
  sleep: "data:image/png;base64,",
};

const FRAME_KEYS = Object.keys(SPRITE_B64);
const frameImgs = {};
let framesLoaded = 0;
FRAME_KEYS.forEach(k=>{
  const img = new Image();
  img.onload = ()=>{ framesLoaded++; };
  img.src = SPRITE_B64[k];
  frameImgs[k] = img;
});

/* ============================================================
   Canvas 初期化
   ============================================================ */
const canvas = document.getElementById('game');
const ctx = canvas.getContext('2d');
const W = canvas.width, H = canvas.height;
const GROUND_Y = 372;

/* レスポンシブ：画面サイズに応じて #wrap をリサイズ（16:9固定） */
const wrapEl = document.getElementById('wrap');
function fitWrap(){
  const vw = window.innerWidth, vh = window.innerHeight;
  const margin = 0;
  let w = vw - margin, h = w * (450/800);
  if(h > vh - margin){ h = vh - margin; w = h * (800/450); }
  wrapEl.style.width = Math.floor(w)+'px';
  wrapEl.style.height = Math.floor(h)+'px';
}
window.addEventListener('resize', fitWrap);
window.addEventListener('orientationchange', ()=>setTimeout(fitWrap,60));
fitWrap();

const rotateHint = document.getElementById('rotateHint');
document.getElementById('rotateDismiss').addEventListener('click', ()=>{
  rotateHint.classList.remove('enabled');
});


/* ============================================================
   オーディオ（完全コード合成 / 外部音源なし）
   ============================================================ */
let audioCtx = null, bgmGain = null, sfxGain = null;
let muted = false;
let bgmTimer = null;
let nextNoteTime = 0;
let noteIndex = 0;
const TEMPO = 132;
const EIGHTH = 60/TEMPO/2;

const MELODIES = [
  { mel:[523.25,659.25,783.99,659.25, 587.33,698.46,880.00,698.46,
         523.25,659.25,783.99,1046.50,880.00,783.99,659.25,587.33],
    bass:[130.81,196.00,174.61,196.00] },
  { mel:[440,523.25,659.25,523.25, 392.00,493.88,587.33,493.88,
         440,523.25,659.25,783.99,659.25,587.33,523.25,440],
    bass:[110,164.81,130.81,146.83] },
  { mel:[392,466.16,587.33,466.16, 349.23,440,523.25,440,
         392,466.16,587.33,698.46,587.33,523.25,466.16,392],
    bass:[98,130.81,116.54,130.81] },
];

function ensureAudio(){
  if(audioCtx) return;
  audioCtx = new (window.AudioContext||window.webkitAudioContext)();
  bgmGain = audioCtx.createGain(); bgmGain.gain.value = 0.10;
  sfxGain = audioCtx.createGain(); sfxGain.gain.value = 0.35;
  bgmGain.connect(audioCtx.destination);
  sfxGain.connect(audioCtx.destination);
  nextNoteTime = audioCtx.currentTime + 0.1;
  bgmTimer = setInterval(scheduleBgm, 25);
}

function tone(t, freq, dur, type, gainVal, dest, glideTo){
  const o = audioCtx.createOscillator();
  const g = audioCtx.createGain();
  o.type = type;
  o.frequency.setValueAtTime(freq, t);
  if(glideTo) o.frequency.exponentialRampToValueAtTime(glideTo, t+dur);
  g.gain.setValueAtTime(0.0001, t);
  g.gain.exponentialRampToValueAtTime(gainVal, t+0.012);
  g.gain.exponentialRampToValueAtTime(0.0001, t+dur);
  o.connect(g); g.connect(dest);
  o.start(t); o.stop(t+dur+0.02);
}

function scheduleBgm(){
  if(!audioCtx) return;
  while(nextNoteTime < audioCtx.currentTime + 0.12){
    if(!muted){
      const set = MELODIES[currentStageIndex % MELODIES.length];
      const m = set.mel[noteIndex % set.mel.length];
      tone(nextNoteTime, m, EIGHTH*0.85, 'square', 0.09, bgmGain);
      if(noteIndex % 4 === 0){
        const b = set.bass[(noteIndex/4|0) % set.bass.length];
        tone(nextNoteTime, b/2, EIGHTH*4*0.9, 'triangle', 0.15, bgmGain);
      }
    }
    nextNoteTime += EIGHTH;
    noteIndex++;
  }
}

function sfxJump(){ if(!audioCtx||muted) return; const t=audioCtx.currentTime; tone(t,300,0.14,'square',0.22,sfxGain,680); }
function sfxDoubleJump(){ if(!audioCtx||muted) return; const t=audioCtx.currentTime; tone(t,420,0.16,'square',0.22,sfxGain,900); tone(t+0.04,600,0.14,'triangle',0.18,sfxGain,1100); }
function sfxDash(){ if(!audioCtx||muted) return; const t=audioCtx.currentTime; tone(t,200,0.10,'sawtooth',0.12,sfxGain,340); }
function sfxBone(){ if(!audioCtx||muted) return; const t=audioCtx.currentTime; tone(t,880,0.09,'square',0.20,sfxGain); tone(t+0.07,1318.5,0.12,'square',0.20,sfxGain); }
function sfxStomp(){ if(!audioCtx||muted) return; const t=audioCtx.currentTime; tone(t,220,0.16,'sine',0.30,sfxGain,60); }
function sfxHurt(){ if(!audioCtx||muted) return; const t=audioCtx.currentTime; tone(t,420,0.26,'sawtooth',0.22,sfxGain,110); }
function sfxGoal(){ if(!audioCtx||muted) return; const t=audioCtx.currentTime; [523.25,659.25,783.99,1046.50].forEach((f,i)=>tone(t+i*0.13,f,0.22,'square',0.22,sfxGain)); }
function sfxOver(){ if(!audioCtx||muted) return; const t=audioCtx.currentTime; [392.00,329.63,261.63,196.00].forEach((f,i)=>tone(t+i*0.17,f,0.3,'triangle',0.22,sfxGain)); }
function sfxBossHit(){ if(!audioCtx||muted) return; const t=audioCtx.currentTime; tone(t,180,0.18,'sawtooth',0.28,sfxGain,90); tone(t+0.02,260,0.14,'square',0.18,sfxGain,120); }
function sfxBossDefeat(){ if(!audioCtx||muted) return; const t=audioCtx.currentTime; [659.25,587.33,523.25,440,349.23,293.66,233.08].forEach((f,i)=>tone(t+i*0.09,f,0.3,'sawtooth',0.22,sfxGain,f*0.6)); }
function sfxStageClear(){ if(!audioCtx||muted) return; const t=audioCtx.currentTime; [523.25,659.25,783.99,1046.50,1318.5].forEach((f,i)=>tone(t+i*0.11,f,0.2,'triangle',0.22,sfxGain)); }

document.getElementById('soundBtn').addEventListener('click', ()=>{
  muted = !muted;
  document.getElementById('soundBtn').textContent = muted ? '🔇' : '🔊';
  if(bgmGain) bgmGain.gain.value = muted ? 0 : 0.10;
});

/* ============================================================
   物理定数
   ============================================================ */
const GRAVITY = 0.62;
const JUMP_V = -13.0;
const JUMP2_V = -11.2;
const MOVE_SPEED = 4.1;
const DASH_SPEED = 6.9;
const MAX_FALL = 15;
const HIT_W = 34, HIT_H = 58;
const DRAW_H = 78;

/* ============================================================
   ステージ定義
   ============================================================ */
function E(type,x,y,minX,maxX,speed){
  return { type, x, y, baseY:y, w:36, h:32, minX, maxX, speed, dir:1,
    alive:true, squish:0, vy:0, onGround:true, flyPhase:Math.random()*Math.PI*2,
    hurtFlash:0 };
}
function B(x,y){ return { x, y, baseY:y, r:12, collected:false, bob:Math.random()*Math.PI*2 }; }
function P(x,y,w,h,moving){ return { x,y,w,h, moving:!!moving, baseX:x, baseY:y, phase:Math.random()*Math.PI*2 }; }

function makeBossDef(type,name,x,hp){
  return { type, name, x, y: GROUND_Y-110, w:96, h:104, hp, maxHp:hp,
    minX:x-150, maxX:x+150 };
}

const STAGES = [
  {
    key:'meadow',
    short:'STAGE 1\nはじまりの草原',
    name:'はじまりの草原',
    skyTop:'#6fc6ff', skyBottom:'#bdeaff',
    hillColor:'#5a9a33', hillColor2:'#4a7f29',
    groundTop:'#7fc24a', groundDark:'#52822f',
    levelW: 3300,
    pits: [],
    platforms: [
      P(620,300,140,22), P(900,250,120,22), P(1500,310,160,22),
      P(1900,260,120,22), P(2300,300,160,22), P(2650,230,120,22),
    ],
    enemies: [
      E('walker',520,GROUND_Y-32,460,760,1.6),
      E('walker',1150,GROUND_Y-32,1080,1380,1.7),
      E('flyer',1700,220,1650,2050,1.8),
      E('walker',2050,GROUND_Y-32,1980,2280,1.8),
      E('flyer',2500,200,2450,2850,2.0),
    ],
    bones: (()=>{
      const arr=[];
      for(let i=0;i<10;i++) arr.push(B(380+i*230, GROUND_Y-70 - (i%3)*18));
      arr.push(B(660,250),B(940,200),B(1530,260),B(1930,210),B(2330,250),B(2680,180));
      return arr;
    })(),
    boss: makeBossDef('crab','オオガニ ばさみ丸',3050,5),
    goalX: 3220,
